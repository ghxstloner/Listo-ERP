// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id               Int       @id @default(autoincrement())
  code             String    @unique // ISO 3166-1 alpha-2 (PA, VE, CO, etc.)
  name             String
  taxDocumentTypes Json // [{"code": "RUC", "name": "RUC", "hasCheckDigit": true}, ...]
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  companies        Company[]
}

model Company {
  id             Int     @id @default(autoincrement())
  name           String
  primaryColor   String  @default("#ff6600")
  secondaryColor String  @default("#180900")
  isActive       Boolean @default(true)

  // Contact information
  address String?
  city    String?
  phone1  String?
  phone2  String?
  email1  String?
  email2  String?

  // Tax information
  countryId         Int?
  taxDocumentType   String? // RUC, RIF, NIT, etc.
  taxDocumentNumber String?
  taxCheckDigit     String? // Dígito verificador (Panamá)
  fiscalName        String? // Razón social

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  companyLogo             String?                  @default("")
  defaultCurrencyId       Int?
  companyUsers            CompanyUser[]
  roles                   CompanyRole[]
  branches                branch[]
  tills                   till[]
  departments             Department[]
  subdepartments          Subdepartment[]
  categories              Category[]
  subcategories           Subcategory[]
  suppliers               Supplier[]
  purchaseOrders          PurchaseOrder[]
  inventoryTransfers      InventoryTransfer[]
  customers               Customer[]
  sellers                 Seller[]
  sellerUsers             SellerUser[]
  products                Product[]
  defaultCurrency         Currency?                @relation("CompanyDefaultCurrency", fields: [defaultCurrencyId], references: [id])
  exchangeRates           ExchangeRate[]
  paymentMethods          PaymentMethod[]
  country                 Country?                 @relation(fields: [countryId], references: [id])
  auditLogs               AuditLog[]
  warehouses              Warehouse[]
  inventoryBalances       InventoryBalance[]
  inventoryMovements      InventoryMovement[]
  hierarchyConfig         CompanyHierarchyConfig?
  cashSessions            CashSession[]
  sales                   Sale[]
}

model CompanyUser {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  roles   CompanyUserRole[]

  @@unique([companyId, userId])
}

// Kept only for compatibility with historical migrations. Authorization uses CompanyRole.
enum Role {
  ADMIN
  USER
}

model CompanyRole {
  id          Int       @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions CompanyRolePermission[]
  users       CompanyUserRole[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Permission {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles       CompanyRolePermission[]
}

model CompanyRolePermission {
  roleId       Int
  permissionId Int

  role       CompanyRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model CompanyUserRole {
  companyUserId Int
  roleId        Int

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  role        CompanyRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([companyUserId, roleId])
  @@index([roleId])
}

model User {
  id                   Int           @id @default(autoincrement())
  email                String        @unique
  password             String
  name                 String
  userCode             String?       @unique
  isActive             Boolean       @default(true)
  resetPasswordCode    String?
  resetPasswordExpires DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  companyUsers         CompanyUser[]
  sellerUsers          SellerUser[]
  auditLogs            AuditLog[]
  openedCashSessions   CashSession[] @relation("CashSessionOpenedBy")
  closedCashSessions   CashSession[] @relation("CashSessionClosedBy")
  sales                Sale[]
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  PASSWORD_CHANGE
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  companyId   Int?
  action      AuditAction
  description String
  section     String
  createdAt   DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
}

model branch {
  id                   Int                      @id @default(autoincrement())
  name                 String
  address              String?
  phone                String?
  branchCode           String?                  @unique
  isActive             Boolean                  @default(true)
  companyId            Int
  currencyId           Int?
  company              Company                  @relation(fields: [companyId], references: [id])
  currency             Currency?                @relation(fields: [currencyId], references: [id])
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  tills                till[]
  warehouses           WarehouseBranch[]
  cashSessions         CashSession[]
  sales                Sale[]

  @@unique([companyId, branchCode])
}

model till {
  id           Int           @id @default(autoincrement())
  tillCode     String        @unique
  tillName     String
  isActive     Boolean       @default(true)
  companyId    Int
  branchId     Int
  branch       branch        @relation(fields: [branchId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id])
  cashSessions CashSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([branchId, tillCode])
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

model CashSession {
  id                    Int               @id @default(autoincrement())
  companyId             Int
  branchId              Int
  tillId                Int
  openedByUserId        Int
  closedByUserId        Int?
  status                CashSessionStatus @default(OPEN)
  openedAt              DateTime          @default(now())
  closedAt              DateTime?
  openingAmount         Decimal           @db.Decimal(18, 4)
  expectedClosingAmount Decimal?          @db.Decimal(18, 4)
  declaredClosingAmount Decimal?          @db.Decimal(18, 4)
  differenceAmount      Decimal?          @db.Decimal(18, 4)
  openingNote           String?
  closingNote           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  company      Company @relation(fields: [companyId], references: [id])
  branch       branch  @relation(fields: [branchId], references: [id])
  till         till    @relation(fields: [tillId], references: [id])
  sales        Sale[]
  openedByUser User    @relation("CashSessionOpenedBy", fields: [openedByUserId], references: [id])
  closedByUser User?   @relation("CashSessionClosedBy", fields: [closedByUserId], references: [id])

  @@index([companyId, status])
  @@index([branchId])
  @@index([tillId])
  @@index([openedByUserId])
  @@index([openedAt])
}

model Currency {
  id                Int               @id @default(autoincrement())
  code              String            @unique
  name              String
  symbol            String
  companiesDefault  Company[]         @relation("CompanyDefaultCurrency")
  branches          branch[]
  exchangeRatesFrom ExchangeRate[]    @relation("ExchangeRateFrom")
  exchangeRatesTo   ExchangeRate[]    @relation("ExchangeRateTo")
  supplierProducts  SupplierProduct[]
  purchaseOrders    PurchaseOrder[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ExchangeRate {
  id             Int      @id @default(autoincrement())
  companyId      Int
  fromCurrencyId Int
  toCurrencyId   Int
  date           DateTime @db.Date
  rate           Decimal  @db.Decimal(18, 6)
  company        Company  @relation(fields: [companyId], references: [id])
  fromCurrency   Currency @relation("ExchangeRateFrom", fields: [fromCurrencyId], references: [id])
  toCurrency     Currency @relation("ExchangeRateTo", fields: [toCurrencyId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, fromCurrencyId, toCurrencyId, date])
}

model PaymentMethod {
  id                Int      @id @default(autoincrement())
  name              String
  code              String
  requiresReference Boolean  @default(false)
  isActive          Boolean  @default(true)
  companyId         Int
  company           Company  @relation(fields: [companyId], references: [id])
  sales             Sale[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, code])
}

model Department {
  id             Int             @id @default(autoincrement())
  name           String
  code           String
  isActive       Boolean         @default(true)
  companyId      Int
  company        Company         @relation(fields: [companyId], references: [id])
  subdepartments Subdepartment[]
  products       Product[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, code])
}

model Subdepartment {
  id           Int        @id @default(autoincrement())
  name         String
  code         String
  isActive     Boolean    @default(true)
  departmentId Int
  companyId    Int        @default(1)
  department   Department @relation(fields: [departmentId], references: [id])
  company      Company    @relation(fields: [companyId], references: [id])
  categories   Category[]
  products     Product[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([companyId, code])
}

model Category {
  id              Int           @id @default(autoincrement())
  name            String
  code            String
  isActive        Boolean       @default(true)
  subdepartmentId Int
  companyId       Int           @default(1)
  subdepartment   Subdepartment @relation(fields: [subdepartmentId], references: [id])
  company         Company       @relation(fields: [companyId], references: [id])
  subcategories   Subcategory[]
  products        Product[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, code])
}

model Subcategory {
  id         Int       @id @default(autoincrement())
  name       String
  code       String
  isActive   Boolean   @default(true)
  categoryId Int
  companyId  Int       @default(1)
  category   Category  @relation(fields: [categoryId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([companyId, code])
}

model Supplier {
  id             Int               @id @default(autoincrement())
  name           String
  taxId          String?
  address        String?
  phone          String?
  email          String?
  contactName    String?
  isActive       Boolean           @default(true)
  companyId      Int
  company        Company           @relation(fields: [companyId], references: [id])
  products       SupplierProduct[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Customer {
  id              Int      @id @default(autoincrement())
  name            String
  taxId           String?
  taxDocumentType String?
  address         String?
  phone           String?
  email           String?
  contactName     String?
  isActive        Boolean  @default(true)
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id])
  sales           Sale[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, taxDocumentType, taxId])
}

model Seller {
  id          Int          @id @default(autoincrement())
  code        String
  name        String
  isActive    Boolean      @default(true)
  companyId   Int
  company     Company      @relation(fields: [companyId], references: [id])
  sellerUsers SellerUser[]
  sales       Sale[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([companyId, code])
}

model SellerUser {
  id        Int      @id @default(autoincrement())
  sellerId  Int
  userId    Int
  companyId Int
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  @@unique([sellerId, userId])
  @@index([companyId])
  @@index([userId])
}

model Product {
  id                      Int                      @id @default(autoincrement())
  sku                     String
  name                    String
  description             String?
  salePrice               Decimal                  @db.Decimal(18, 4)
  costPrice               Decimal?                 @db.Decimal(18, 4)
  taxRate                 Decimal?                 @db.Decimal(5, 4)
  isActive                Boolean                  @default(true)
  companyId               Int
  departmentId            Int
  subdepartmentId         Int?
  categoryId              Int?
  subcategoryId           Int?
  unit                    String?
  image                   String? // ruta relativa y nombre del archivo (ej. products/abc123.jpg)
  company                 Company                  @relation(fields: [companyId], references: [id])
  department              Department               @relation(fields: [departmentId], references: [id])
  subdepartment           Subdepartment?           @relation(fields: [subdepartmentId], references: [id])
  category                Category?                @relation(fields: [categoryId], references: [id])
  subcategory             Subcategory?             @relation(fields: [subcategoryId], references: [id])
  supplierProducts        SupplierProduct[]
  purchaseOrderItems      PurchaseOrderItem[]
  inventoryBalances       InventoryBalance[]
  inventoryMovements      InventoryMovement[]
  saleItems               SaleItem[]
  transferItems           InventoryTransferItem[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@unique([companyId, sku])
}

model SupplierProduct {
  id              Int      @id @default(autoincrement())
  supplierId      Int
  productId       Int
  supplierSku     String?
  referenceCost   Decimal? @db.Decimal(18, 4)
  currencyId      Int?
  minimumQuantity Decimal? @db.Decimal(18, 4)
  leadTimeDays    Int?
  isPreferred     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  currency Currency? @relation(fields: [currencyId], references: [id])

  @@unique([supplierId, productId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum InventoryMovementType {
  PURCHASE_RECEIPT
  MANUAL_ENTRY
  INVENTORY_ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  SALE
}

enum InventoryTransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id               Int                 @id @default(autoincrement())
  companyId        Int
  supplierId       Int
  warehouseId      Int
  currencyId       Int
  exchangeRate     Decimal             @default(1) @db.Decimal(18, 6)
  status           PurchaseOrderStatus @default(PENDING)
  notes            String?
  receivedAt       DateTime?
  receivedByUserId Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  company   Company             @relation(fields: [companyId], references: [id])
  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  currency  Currency            @relation(fields: [currencyId], references: [id])
  items     PurchaseOrderItem[]

  @@index([companyId, status])
  @@index([supplierId])
  @@index([warehouseId])
}

model PurchaseOrderItem {
  id              Int      @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int
  supplierSku     String?
  quantity        Decimal  @db.Decimal(18, 4)
  unitCost        Decimal  @db.Decimal(18, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product             @relation(fields: [productId], references: [id])
  movements     InventoryMovement[]

  @@unique([purchaseOrderId, productId])
}

model InventoryBalance {
  id          Int      @id @default(autoincrement())
  companyId   Int
  warehouseId Int
  productId   Int
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([companyId, productId])
}

model InventoryMovement {
  id                  Int                   @id @default(autoincrement())
  companyId           Int
  warehouseId         Int
  productId           Int
  type                InventoryMovementType
  quantity            Decimal               @db.Decimal(18, 4)
  unitCost            Decimal               @db.Decimal(18, 4)
  balanceAfter        Decimal               @db.Decimal(18, 4)
  purchaseOrderId     Int?
  purchaseOrderItemId Int?
  saleItemId          Int?
  createdByUserId     Int
  createdAt           DateTime              @default(now())

  company           Company            @relation(fields: [companyId], references: [id])
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  saleItem          SaleItem?          @relation(fields: [saleItemId], references: [id])

  @@unique([purchaseOrderItemId])
  @@index([saleItemId])
  @@index([companyId, warehouseId, productId, createdAt])
  @@index([purchaseOrderId])
}

model Warehouse {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  address            String?
  isActive           Boolean             @default(true)
  companyId          Int
  company            Company             @relation(fields: [companyId], references: [id])
  branches           WarehouseBranch[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  purchaseOrders        PurchaseOrder[]
  sourceTransfers       InventoryTransfer[] @relation("TransferSourceWarehouse")
  destinationTransfers  InventoryTransfer[] @relation("TransferDestinationWarehouse")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([companyId, code])
}

model InventoryTransfer {
  id                     Int                     @id @default(autoincrement())
  companyId              Int
  sourceWarehouseId      Int
  destinationWarehouseId Int
  status              InventoryTransferStatus @default(PENDING)
  notes               String?
  dispatchedAt        DateTime?
  dispatchedByUserId  Int?
  receivedAt          DateTime?
  receivedByUserId    Int?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  company              Company                 @relation(fields: [companyId], references: [id])
  sourceWarehouse      Warehouse               @relation("TransferSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destinationWarehouse Warehouse               @relation("TransferDestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  items             InventoryTransferItem[]

  @@index([companyId, status])
  @@index([sourceWarehouseId])
  @@index([destinationWarehouseId])
}

model InventoryTransferItem {
  id         Int      @id @default(autoincrement())
  transferId Int
  productId  Int
  quantity   Decimal  @db.Decimal(18, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transfer InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])

  @@unique([transferId, productId])
}

model WarehouseBranch {
  id          Int       @id @default(autoincrement())
  warehouseId Int
  branchId    Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  branch      branch    @relation(fields: [branchId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([warehouseId, branchId])
}

model Sale {
  id              Int           @id @default(autoincrement())
  companyId       Int
  branchId        Int
  cashSessionId   Int
  customerId      Int
  sellerId        Int
  paymentMethodId Int
  createdByUserId Int
  subtotal        Decimal       @db.Decimal(18, 4)
  taxAmount       Decimal       @db.Decimal(18, 4)
  total           Decimal       @db.Decimal(18, 4)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id])
  branch        branch        @relation(fields: [branchId], references: [id])
  cashSession   CashSession   @relation(fields: [cashSessionId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  seller        Seller        @relation(fields: [sellerId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  createdByUser User          @relation(fields: [createdByUserId], references: [id])
  items         SaleItem[]

  @@index([companyId, createdAt])
  @@index([cashSessionId])
  @@index([customerId])
  @@index([sellerId])
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Decimal  @db.Decimal(18, 4)
  unitPrice Decimal  @db.Decimal(18, 4)
  taxRate   Decimal  @db.Decimal(5, 4)
  taxAmount Decimal  @db.Decimal(18, 4)
  lineTotal Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale               Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])
  inventoryMovements InventoryMovement[]

  @@unique([saleId, productId])
  @@index([productId])
}

model CompanyHierarchyConfig {
  id         Int     @id @default(autoincrement())
  companyId  Int     @unique
  level1Name String  @default("Departamento")
  level2Name String  @default("Subdepartamento")
  level3Name String  @default("Categoría")
  level4Name String  @default("Subcategoría")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
